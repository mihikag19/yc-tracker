# ── YC Tracker Config ──────────────────────────────────────────

# Your Gmail address
GMAIL_USER=you@gmail.com

# Gmail App Password (NOT your real password — see README for setup)
# Get one at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Who receives the emails (defaults to GMAIL_USER if left blank)
NOTIFY_EMAIL=you@gmail.com

# Anthropic API key — used to generate plain-English summaries of each startup
# and who built it. Get one at: https://console.anthropic.com/
# Optional: if omitted, emails will show raw descriptions instead.
ANTHROPIC_API_KEY=sk-ant-...
